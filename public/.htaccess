# Serve directory index files automatically
DirectoryIndex index.html

# ============================================================
# URL REWRITING — serve /path as /path/index.html
# Required for Next.js static export on Apache (GoDaddy)
# Deploys to /public_html/RunPayway/
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /RunPayway/

  # 301 redirects — consolidated/deleted pages
  RewriteRule ^how-runpayway-works/?$ /RunPayway/how-it-works/ [R=301,L]
  RewriteRule ^interpretation-contract/?$ /RunPayway/methodology/ [R=301,L]
  RewriteRule ^version-governance/?$ /RunPayway/methodology/ [R=301,L]
  RewriteRule ^badge/?$ /RunPayway/ [R=301,L]
  RewriteRule ^checkout-placeholder/?$ /RunPayway/pricing/ [R=301,L]

  # If the request is not a file or directory, try /path/index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]
</IfModule>

# ============================================================
# CACHING
# ============================================================

# Cache hashed assets (immutable — fingerprinted filenames)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# HTML pages: never cache — always fetch fresh from server
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Index files in directories: never cache
<IfModule mod_headers.c>
  <Files "index.html">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>
