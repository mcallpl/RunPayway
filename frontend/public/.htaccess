# RunPayway Frontend - Allow all static page access
# Enable directory index for Next.js static export
DirectoryIndex index.html

# Allow query strings on all pages
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the requested file or directory exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # For any other request, serve the 404 page
    RewriteRule ^ /RunPayway/404.html [L]
</IfModule>
